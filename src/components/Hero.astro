      </div>
      <div class="strip-logo-item">
        <img src="https://www.google.com/s2/favicons?domain=zoom.us&sz=64" alt="Zoom" width="28" height="28" />
        <span>Zoom</span>
      </div>
      <div class="strip-logo-item">
        <img src="https://www.google.com/s2/favicons?domain=calendar.google.com&sz=64" alt="Calendar" width="28" height="28" />
        <span>Calendar</span>
      </div>
      <div class="strip-logo-item">
        <img src="https://www.google.com/s2/favicons?domain=salesforce.com&sz=64" alt="Salesforce" width="28" height="28" />
