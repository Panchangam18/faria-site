<!-- ─── Hero section ─────────────────────────────────── -->
<section class="hero">

  <!-- Tagline -->
  <div class="headline">
    <h1>Your workload,<br/><span class="headline-accent">made lighter</span></h1>
    <p class="subheadline">The only AI assistant that works from everywhere you do.</p>
  </div>

  <!-- Command bar mock -->
  <div class="command-bar-wrapper">
    <div class="cb-glow" aria-hidden="true"></div>
    <div class="cb-glow-core" aria-hidden="true"></div>
    <div class="cb-glow-rays" aria-hidden="true"></div>
    <div class="command-bar-mock">
      <div class="cb-agent-area cb-collapsed">
        <div class="cb-response" id="cb-response"></div>
        <div class="cb-footer">
          <div class="cb-status" id="cb-state-thinking">
            <div class="cb-status-logo">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="105 30 190 310" fill="currentColor">
                <path d="M 238.097656 161.742188 C 212.027344 202.410156 156.050781 227.769531 161.972656 285.457031 C 163.976562 305.269531 180.035156 334.132812 199.847656 338.304688 C 135.195312 332.382812 82.347656 265.3125 128.9375 189.1875 C 147.375 159.070312 188.375 140.175781 202.976562 108.890625 C 216.53125 81.78125 205.0625 46.324219 174.820312 37.980469 C 204.019531 33.8125 240.976656 57.085938 249.191406 85.949219 C 256.867188 112.726562 252.695312 139.84375 238.097656 161.742188"/>
                <path d="M 261.371094 240.617188 C 292.65625 207.25 277.347656 165.910156 261.371094 152.6875 C 259.621094 195.109375 214.199219 215.757812 194.632812 247.582031 C 187.792969 258.722656 182.789062 270.523438 185.25 289.296875 C 186.792969 301.101562 203.769531 341.183594 250.941406 334.132812 C 238.265625 322.832031 229.839844 312.488281 231.925781 293.71875 C 235.054688 269.734375 246.773438 257.300781 261.371094 240.617188 Z"/>
              </svg>
            </div>
            <span class="cb-status-text">Thinking…</span>
          </div>
          <div class="cb-status cb-status-hidden" id="cb-state-tool">
            <img class="cb-tool-icon" id="cb-tool-icon" src="" alt="" width="14" height="14" />
            <span class="cb-status-text" id="cb-tool-name"></span>
          </div>
        </div>
      </div>

      <div class="cb-divider cb-collapsed"></div>

      <div class="cb-input-area">
        <div class="cb-input-scroll">
          <div class="cb-input-text" id="cb-prompt">follow up with Sarah about Q3</div>
        </div>
        <div class="cb-inline-controls">
          <button class="cb-stop" aria-label="Stop">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512" width="13" height="13" fill="currentColor">
              <path d="M256 48C141.31 48 48 141.31 48 256s93.31 208 208 208 208-93.31 208-208S370.69 48 256 48zm80 288H176V176h160z"/>
            </svg>
          </button>
        </div>
      </div>
    </div>
  </div>

  <!-- CTA -->
  <div class="cta-row">
    <div class="cta-buttons">
      <a href="https://github.com/Panchangam18/faria/releases/latest/download/Faria.dmg" class="cta-download">
        <img class="apple-logo" src={`${import.meta.env.BASE_URL}/apple-logo.png`} alt="" width="18" height="22" />
        Download for Mac
      </a>
    </div>
    <p class="cta-note">Free during beta &middot; macOS 13+</p>
  </div>
</section>

<!-- ─── Features section ─────────────────────────────── -->
<section class="features" id="features">
  <div class="features-inner">
    <div class="features-header">
      <p class="section-eyebrow">Features</p>
      <h2 class="section-title">One prompt.<br/>Every app.</h2>
    </div>
    <div class="features-grid">
      <div class="feature-card">
        <div class="feature-icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
        </div>
        <h3>Natural Language Actions</h3>
        <p>Describe what you want in plain English. Faria translates intent into precise actions across any app on your Mac.</p>
      </div>
      <div class="feature-card">
        <div class="feature-icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
        </div>
        <h3>Screen Awareness</h3>
        <p>Faria sees what's on your screen and understands context — no need to explain what app you're in or what you're looking at.</p>
      </div>
      <div class="feature-card">
        <div class="feature-icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M8 14s1.5 2 4 2 4-2 4-2"/><line x1="9" y1="9" x2="9.01" y2="9"/><line x1="15" y1="9" x2="15.01" y2="9"/></svg>
        </div>
        <h3>Privacy First</h3>
        <p>Everything runs locally on your Mac. Your screen data never leaves your device unless you explicitly approve an action.</p>
      </div>
      <div class="feature-card">
        <div class="feature-icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
        </div>
        <h3>Instant Activation</h3>
        <p>One keyboard shortcut summons the command bar. Type your request, hit enter, and Faria handles the rest — anywhere on your Mac.</p>
      </div>
    </div>
  </div>
</section>

<!-- ─── Use Cases ──────────────────────────────────── -->
<section class="use-cases" id="use-cases">
  <div class="use-cases-inner">
    <div class="uc-header">
      <p class="section-eyebrow">Use Cases</p>
      <h2 class="uc-title">See it work.</h2>
    </div>

    <div class="uc-item">
      <div class="uc-video-col">
        <div class="uc-video-glow" aria-hidden="true"></div>
        <div class="uc-video">
          <video autoplay loop muted playsinline poster="https://pub-ab8e3c5ec1464c95a639fe813b08915d.r2.dev/sales-sheet-poster.webp">
            <source src="https://pub-ab8e3c5ec1464c95a639fe813b08915d.r2.dev/sales-sheet.mp4" type="video/mp4" />
          </video>
        </div>
      </div>
      <div class="uc-text-col">
        <div class="uc-accent-line" aria-hidden="true"></div>
        <h3>Generate a sales sheet</h3>
        <p>Describe the product briefly. Faria builds a complete, branded one-pager — layout, copy, formatting — ready to send.</p>
      </div>
    </div>

    <div class="uc-item uc-item--flipped">
      <div class="uc-video-col">
        <div class="uc-video-glow" aria-hidden="true"></div>
        <div class="uc-video">
          <video autoplay loop muted playsinline poster="https://pub-ab8e3c5ec1464c95a639fe813b08915d.r2.dev/replace-text-jap-doc-poster.webp">
            <source src="https://pub-ab8e3c5ec1464c95a639fe813b08915d.r2.dev/replace-text-jap-doc.mp4" type="video/mp4" />
          </video>
        </div>
      </div>
      <div class="uc-text-col">
        <div class="uc-accent-line" aria-hidden="true"></div>
        <h3>Edit across languages</h3>
        <p>Find and replace inside a Japanese document. Faria reads what's on screen and edits in-place — no plugins, no language barrier.</p>
      </div>
    </div>

    <div class="uc-item">
      <div class="uc-video-col">
        <div class="uc-video-glow" aria-hidden="true"></div>
        <div class="uc-video">
          <video autoplay loop muted playsinline poster="https://pub-ab8e3c5ec1464c95a639fe813b08915d.r2.dev/fill-out-form-abt-me-poster.webp">
            <source src="https://pub-ab8e3c5ec1464c95a639fe813b08915d.r2.dev/fill-out-form-abt-me.mp4" type="video/mp4" />
          </video>
        </div>
      </div>
      <div class="uc-text-col">
        <div class="uc-accent-line" aria-hidden="true"></div>
        <h3>Fill out any form</h3>
        <p>Point Faria at a web form and tell it what to enter. It navigates every field, picks dropdowns, and submits — completely hands-free.</p>
      </div>
    </div>
  </div>
</section>

<!-- ─── Final CTA ────────────────────────────────────── -->
<section class="final-cta" id="download">
  <div class="final-cta-inner">
    <div class="final-cta-glow" aria-hidden="true"></div>
    <h2>Never leave your flow again.</h2>
    <p>No complex setup, no mac mini. Get early access to Faria now.</p>
    <a href="https://github.com/Panchangam18/faria/releases/latest/download/Faria.dmg" class="cta-download cta-download-final">
      <img class="apple-logo" src={`${import.meta.env.BASE_URL}/apple-logo.png`} alt="" width="18" height="22" />
      Download for Mac
    </a>
  </div>
</section>

