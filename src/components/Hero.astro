</style>

<script>
  // ─── Command bar scenario animation ─────────────────
  type Step = {
    kind: 'thinking';
    response: string;
    duration: number;
  } | {
    kind: 'tool';
    icon: string;
    name: string;
    response: string;
    duration: number;
  };

  type Scenario = {
    prompt: string;
    steps: Step[];
  };

  const ICONS: Record<string, string> = {
    gmail: 'https://ssl.gstatic.com/ui/v1/icons/mail/rfr/gmail.ico',
    github: 'https://github.githubassets.com/favicons/favicon-dark.svg',
    gcal: 'https://calendar.google.com/googlecalendar/images/favicons_2020q4/calendar_31.ico',
    slack: 'https://a.slack-edge.com/80588/marketing/img/meta/favicon-32.png',
    gdrive: 'https://ssl.gstatic.com/docs/doclist/images/drive_2022q3_32dp.png',
    notion: 'https://www.notion.so/front-static/favicon.ico',
  };

  const scenarios: Scenario[] = [
    {
      prompt: "follow up with Sarah about Q3",
      steps: [
        { kind: 'thinking',  response: "Checking your recent emails with Sarah…", duration: 1400 },
        { kind: 'tool', icon: ICONS.gmail,    name: 'Gmail: Fetching emails',       response: "Found 3 emails about the Q3 proposal from last week…", duration: 2000 },
        { kind: 'thinking',  response: "Drafting a follow-up based on the open action items…", duration: 1600 },
        { kind: 'tool', icon: ICONS.gmail,    name: 'Gmail: Sending email',          response: "Follow-up sent to sarah@acme.com with next steps.", duration: 1800 },
      ],
    },
    {
      prompt: "schedule a daily standup at 9am",
      steps: [
        { kind: 'thinking',  response: "Checking your calendar for conflicts…", duration: 1400 },
        { kind: 'tool', icon: ICONS.gcal, name: 'Google Calendar: Finding events', response: "No conflicts found in the 9–9:30am slot…", duration: 1800 },
        { kind: 'tool', icon: ICONS.gcal, name: 'Google Calendar: Creating event',  response: "Recurring standup created Mon–Fri at 9:00am…", duration: 2000 },
        { kind: 'tool', icon: ICONS.slack,    name: 'Slack: Sending message',        response: "Notified #engineering about the new standup.", duration: 1600 },
      ],
    },
    {
      prompt: "share the latest sales deck",
      steps: [
        { kind: 'thinking',  response: "Searching your Google Drive for recent presentations…", duration: 1400 },
        { kind: 'tool', icon: ICONS.gdrive, name: 'Google Drive: Searching files', response: "Found \"Q3 Sales Deck v2\" updated yesterday…", duration: 2000 },
        { kind: 'tool', icon: ICONS.slack,    name: 'Slack: Sending message',        response: "Shared the deck link in #sales with a summary.", duration: 1800 },
      ],
    },
    {
      prompt: "save these notes to Notion",
      steps: [
        { kind: 'thinking',  response: "Looking at what's on screen…", duration: 1200 },
        { kind: 'tool', icon: '',               name: 'Executing actions',              response: "Captured meeting notes from the current window…", duration: 2000 },
        { kind: 'thinking',  response: "Formatting notes with key decisions and action items…", duration: 1600 },
        { kind: 'tool', icon: ICONS.notion,    name: 'Notion: Creating page',         response: "Notes saved to \"Meeting Notes / March 19 Sync\".", duration: 1800 },
      ],
    },
    {
      prompt: "file a GitHub issue for the login bug",
      steps: [
        { kind: 'thinking',  response: "Reviewing recent Slack messages about the login bug…", duration: 1400 },
        { kind: 'tool', icon: ICONS.slack,    name: 'Slack: Fetching messages',      response: "Found discussion in #frontend from this morning…", duration: 2000 },
        { kind: 'thinking',  response: "Drafting issue with reproduction steps…", duration: 1600 },
        { kind: 'tool', icon: ICONS.github,   name: 'GitHub: Creating issue',        response: "Issue #247 created: \"Login redirect fails on Safari\".", duration: 1800 },
      ],
    },
  ];

  function fade(el: HTMLElement, newContent: () => void) {
    el.style.transition = 'opacity 0.25s';
    el.style.opacity = '0';
    setTimeout(() => {
      newContent();
      el.style.opacity = '1';
    }, 260);
  }

  const promptEl    = document.getElementById('cb-prompt')         as HTMLElement;
  const responseEl  = document.getElementById('cb-response')       as HTMLElement;
  const stateThink  = document.getElementById('cb-state-thinking') as HTMLElement;
  const stateTool   = document.getElementById('cb-state-tool')     as HTMLElement;
  const toolIcon    = document.getElementById('cb-tool-icon')      as HTMLImageElement;
  const toolName    = document.getElementById('cb-tool-name')      as HTMLElement;
  const agentArea   = document.querySelector('.cb-agent-area')     as HTMLElement;
  const divider     = document.querySelector('.cb-divider')        as HTMLElement;

  function collapseAgent() {
    agentArea.classList.add('cb-collapsed');
    divider.classList.add('cb-collapsed');
  }

  function expandAgent() {
    agentArea.classList.remove('cb-collapsed');
    divider.classList.remove('cb-collapsed');
  }

  function showThinking() {
    stateThink.classList.remove('cb-status-hidden');
    stateTool.classList.add('cb-status-hidden');
  }

  function showTool(icon: string, name: string) {
    stateThink.classList.add('cb-status-hidden');
    stateTool.classList.remove('cb-status-hidden');
    if (icon) {
      toolIcon.style.display = '';
      toolIcon.src = icon;
      toolIcon.alt = name;
    } else {
      toolIcon.style.display = 'none';
    }
    toolName.textContent = name + '…';
  }

  async function typeText(el: HTMLElement, text: string, charDelay = 35) {
    el.textContent = '';
    for (let i = 0; i < text.length; i++) {
      el.textContent += text[i];
      await sleep(charDelay + Math.random() * 20 - 10);
    }
  }

  async function runScenario(scenario: Scenario) {
    // 1. Show the prompt typed out, agent area collapsed (just input visible)
    collapseAgent();
    promptEl.textContent = '';
    await sleep(300);
    await typeText(promptEl, scenario.prompt);
    await sleep(400);

    // 2. Expand agent area with thinking state (no response yet, just status)
    responseEl.textContent = '';
    showThinking();
    expandAgent();
    await sleep(1400);

    // 3. Execute steps — each shows response text + status
    for (const step of scenario.steps) {
      if (step.kind === 'thinking') {
        showThinking();
      } else {
        showTool(step.icon, step.name);
      }
      fade(responseEl, () => { responseEl.textContent = step.response; });
      await sleep(step.duration);
    }

    // 4. Collapse agent area and clear the query (like the real app)
    await sleep(800);
    collapseAgent();
    fade(promptEl, () => { promptEl.textContent = ''; });
    await sleep(600);
  }

  function sleep(ms: number) {
    return new Promise(resolve => setTimeout(resolve, ms));
  }

  async function loop() {
    let i = 0;
    while (true) {
      await runScenario(scenarios[i % scenarios.length]);
      i++;
    }
  }

  loop();

  // ─── Scroll-triggered reveals ─────────────────────────
  const revealTargets = document.querySelectorAll('.features-header, .feature-card, .uc-item, .final-cta-inner');
  revealTargets.forEach(el => el.classList.add('scroll-reveal'));

  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        // Stagger children
        const parent = entry.target.closest('.features-grid');
        if (parent) {
          const siblings = Array.from(parent.querySelectorAll('.scroll-reveal'));
          const idx = siblings.indexOf(entry.target as Element);
          (entry.target as HTMLElement).style.transitionDelay = `${idx * 100}ms`;
        }
        entry.target.classList.add('is-visible');
        observer.unobserve(entry.target);
      }
    });
  }, { threshold: 0.15, rootMargin: '0px 0px -40px 0px' });

  revealTargets.forEach(el => observer.observe(el));
</script>
