<style>
  /* ─── Top nav bar ──────────────────────────────────── */
  .top-bar {
    position: fixed;
    top: 12px;
    left: max(16px, 12vw);
    right: max(16px, 12vw);
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 14px 24px;
    background: rgba(24, 26, 32, 0.72);
    backdrop-filter: blur(24px) saturate(1.5);
    -webkit-backdrop-filter: blur(24px) saturate(1.5);
    border: 1px solid rgba(234, 224, 213, 0.1);
    border-radius: 6px;
  }

  .nav-left {
    display: flex;
    align-items: center;
  }

  .nav-logo {
    display: flex;
    align-items: center;
    gap: 6px;
    text-decoration: none;
    color: var(--color-text);
  }

  .nav-logo svg {
    flex-shrink: 0;
    transform-origin: center bottom;
    animation: flame-flicker 2.5s ease-in-out infinite;
  }

  @keyframes flame-flicker {
    0%, 100% {
      transform: translateY(0) scaleY(1) scaleX(1);
    }
    50% {
      transform: translateY(-1.5px) scaleY(1.07) scaleX(0.96);
    }
  }

  .nav-wordmark {
    font-family: var(--font);
    font-size: 22px;
    font-weight: 400;
    letter-spacing: -0.01em;
    color: var(--color-text);
  }

  .nav-center {
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    align-items: center;
    gap: 32px;
  }

  .nav-right {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .nav-link {
    font-family: var(--font);
    font-size: 13.5px;
    font-weight: 400;
    color: var(--color-text-muted);
    text-decoration: none;
    letter-spacing: 0.01em;
    transition: color 0.25s;
  }

  .nav-link:hover {
    color: var(--color-text);
  }

  .nav-install {
    display: inline-flex;
    align-items: center;
    padding: 7px 20px;
    border-radius: 100px;
    background: var(--color-accent);
    border: none;
    color: var(--color-bg);
    font-family: var(--font);
    font-size: 13.5px;
    font-weight: 600;
    text-decoration: none;
    letter-spacing: 0.01em;
    transition: all 0.3s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .nav-install:hover {
    background: var(--color-accent-warm);
    transform: translateY(-1px);
  }

  /* ─── Hero section ─────────────────────────────────── */
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 36px;
    padding: clamp(120px, 20vh, 200px) var(--space-lg) var(--space-xl);
    padding-bottom: calc(var(--space-2xl) + 40px);
    overflow: visible;
    isolation: isolate;
  }


  /* ─── Headline ─────────────────────────────────────── */
  .headline {
    position: relative;
    z-index: 2;
    text-align: center;
    max-width: 700px;
  }

  h1 {
    font-size: clamp(2.8rem, 7vw, 5.2rem);
    font-weight: 300;
    line-height: 1.08;
    letter-spacing: -0.035em;
    color: var(--color-text);
  }

  .headline-accent {
    background: linear-gradient(135deg, var(--color-accent) 0%, #e0c9a8 45%, var(--color-accent-warm) 100%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .subheadline {
    margin-top: 20px;
    font-size: clamp(1rem, 2vw, 1.15rem);
    font-weight: 350;
    line-height: 1.6;
    color: var(--color-text-muted);
    max-width: 480px;
    margin-left: auto;
    margin-right: auto;
    letter-spacing: 0.005em;
  }

  /* ─── Command bar mock ─────────────────────────────── */
  .command-bar-wrapper {
    position: relative;
    z-index: 3;
    pointer-events: none;
    /* Fixed height container so dynamic command bar doesn't shift layout */
    height: 140px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .command-bar-mock {
    pointer-events: auto;
  }

  /* Outer wide wash — fills the area with warm light */
  .cb-glow {
    position: absolute;
    inset: -300px -400px;
    background: radial-gradient(ellipse 100% 80% at center, rgba(198, 172, 143, 0.28) 0%, rgba(198, 172, 143, 0.10) 35%, transparent 65%);
    border-radius: 50%;
    filter: blur(120px);
    z-index: -1;
    animation: glow-outer 5s ease-in-out infinite;
  }

  /* Hot bright core — concentrated behind the bar */
  .cb-glow-core {
    position: absolute;
    inset: -80px -120px;
    background: radial-gradient(ellipse 100% 100% at center, rgba(212, 184, 150, 0.45) 0%, rgba(198, 172, 143, 0.18) 40%, transparent 70%);
    border-radius: 50%;
    filter: blur(50px);
    z-index: -1;
    animation: glow-core 3.5s ease-in-out infinite;
  }

  /* Vertical rays — tall narrow streaks shooting up/down */
  .cb-glow-rays {
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    width: 300px;
    height: 700px;
    background: radial-gradient(ellipse 40% 100% at center, rgba(198, 172, 143, 0.18) 0%, transparent 60%);
    filter: blur(60px);
    z-index: -1;
    animation: glow-rays 6s ease-in-out infinite;
  }

  @keyframes glow-outer {
    0%, 100% { opacity: 0.55; transform: scale(0.95); }
    50% { opacity: 1; transform: scale(1.12); }
  }

  @keyframes glow-core {
    0%, 100% { opacity: 0.6; transform: scale(0.9); }
    50% { opacity: 1; transform: scale(1.2); }
  }

  @keyframes glow-rays {
    0%, 100% { opacity: 0.45; transform: translate(-50%, -50%) scaleY(0.9); }
    50% { opacity: 1; transform: translate(-50%, -50%) scaleY(1.15); }
  }

  .command-bar-mock {
    width: 350px;
    background: rgba(28, 30, 38, 0.92);
    border: 1px solid rgba(234, 224, 213, 0.1);
    border-radius: 6px;
    backdrop-filter: blur(24px);
    -webkit-backdrop-filter: blur(24px);
    box-shadow:
      0 20px 50px rgba(0, 0, 0, 0.55),
      0 8px 16px rgba(0, 0, 0, 0.35),
      0 0 0 1px rgba(198, 172, 143, 0.04),
      inset 0 1px 0 rgba(255, 255, 255, 0.03);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: all 0.3s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .cb-agent-area {
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    overflow: hidden;
    max-height: 120px;
    transition: max-height 0.3s cubic-bezier(0.22, 1, 0.36, 1),
                opacity 0.25s;
  }

  .cb-agent-area.cb-collapsed {
    max-height: 0 !important;
    opacity: 0;
  }

  .cb-response {
    padding: 8px 16px 0;
    font-size: 13px;
    line-height: 1.6;
    color: var(--color-accent);
    max-height: calc(1.6em * 2 + 8px); /* 2 lines + top padding */
    overflow: hidden;
    transition: opacity 0.3s;
    display: -webkit-box;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
  }

  .cb-response:empty {
    display: none;
  }

  .cb-footer {
    display: flex;
    align-items: center;
    padding: 8px 16px;
    min-width: 0;
  }

  .cb-footer:not(:has(.cb-status:not(.cb-status-hidden))) {
    display: none;
  }

  .cb-status {
    display: flex;
    align-items: center;
    gap: 4px;
    min-width: 0;
    font-size: 13px;
    font-weight: 500;
    color: var(--color-accent);
