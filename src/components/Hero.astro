</style>

<script>
  // ─── Command bar scenario animation ─────────────────
  type Step = {
    kind: 'thinking';
    response: string;
    duration: number;
  } | {
    kind: 'tool';
    icon: string;
    name: string;
    response: string;
    duration: number;
  };

  type Scenario = {
    prompt: string;
    steps: Step[];
  };

  const G = 'https://www.google.com/s2/favicons?domain=';

  const scenarios: Scenario[] = [
    {
      prompt: "write a follow-up email to Sarah about the Q3 proposal",
      steps: [
        { kind: 'thinking',  response: "Reviewing last email thread with Sarah…", duration: 1800 },
        { kind: 'tool', icon: G+'gmail.com',    name: 'Gmail — Reading thread',      response: "Found 3 emails about the Q3 proposal from last week…", duration: 2000 },
        { kind: 'thinking',  response: "Drafting a concise follow-up based on open items…", duration: 1800 },
        { kind: 'tool', icon: G+'gmail.com',    name: 'Gmail — Sending email',        response: "Sending to sarah@acme.com with proposal PDF attached…", duration: 2000 },
      ],
    },
    {
      prompt: "summarize my last 3 Zoom meetings into bullet points",
      steps: [
        { kind: 'thinking',  response: "Finding recent Zoom recordings and transcripts…", duration: 1800 },
        { kind: 'tool', icon: G+'zoom.us',      name: 'Zoom — Fetching transcripts',  response: "Retrieved transcripts: Design sync, Sprint retro, Stakeholder review…", duration: 2200 },
        { kind: 'thinking',  response: "Extracting key decisions and action items from each…", duration: 2000 },
        { kind: 'tool', icon: G+'notion.so',    name: 'Notion — Saving summary',      response: "Saving bullet-point summary to your Meeting Notes page…", duration: 1800 },
      ],
    },
    {
      prompt: "book a morning flight to NYC for next Tuesday",
      steps: [
        { kind: 'thinking',  response: "Checking your travel preferences and frequent flyer accounts…", duration: 1600 },
        { kind: 'tool', icon: G+'google.com/travel', name: 'Google Flights — Searching', response: "Found 4 morning options SFO→JFK on Tuesday under $350…", duration: 2200 },
        { kind: 'thinking',  response: "Selecting best option: UA 472, 8:45am, nonstop…", duration: 1600 },
        { kind: 'tool', icon: G+'calendar.google.com', name: 'Google Calendar — Blocking', response: "Travel day blocked. Reminders set for check-in and departure…", duration: 1800 },
      ],
    },
    {
      prompt: "pull the Q3 revenue numbers from Salesforce",
      steps: [
        { kind: 'thinking',  response: "Connecting to Salesforce and locating Q3 report…", duration: 1800 },
        { kind: 'tool', icon: G+'salesforce.com', name: 'Salesforce — Running report', response: "Q3 revenue: $4.2M closed, $1.8M in pipeline. ARR up 22% YoY…", duration: 2400 },
        { kind: 'thinking',  response: "Formatting summary and preparing export…", duration: 1400 },
        { kind: 'tool', icon: G+'docs.google.com', name: 'Google Sheets — Exporting',  response: "Numbers exported to your Q3 Review spreadsheet…", duration: 1800 },
      ],
    },
    {
      prompt: "schedule a 1:1 with everyone on my team this week",
      steps: [
        { kind: 'thinking',  response: "Fetching team members from Slack and checking calendars…", duration: 1800 },
        { kind: 'tool', icon: G+'slack.com',    name: 'Slack — Reading team list',    response: "Found 5 direct reports. Checking mutual availability…", duration: 2000 },
        { kind: 'tool', icon: G+'calendar.google.com', name: 'Google Calendar — Creating events', response: "Created 5 x 30-min 1:1s across Thursday and Friday…", duration: 2200 },
        { kind: 'thinking',  response: "Sending calendar invites with agenda template attached…", duration: 1600 },
      ],
    },
  ];

  function fade(el: HTMLElement, newContent: () => void) {
    el.style.transition = 'opacity 0.25s';
    el.style.opacity = '0';
    setTimeout(() => {
      newContent();
      el.style.opacity = '1';
    }, 260);
  }

  const promptEl   = document.getElementById('cb-prompt')         as HTMLElement;
  const responseEl = document.getElementById('cb-response')       as HTMLElement;
  const stateThink = document.getElementById('cb-state-thinking') as HTMLElement;
  const stateTool  = document.getElementById('cb-state-tool')     as HTMLElement;
  const toolIcon   = document.getElementById('cb-tool-icon')      as HTMLImageElement;
  const toolName   = document.getElementById('cb-tool-name')      as HTMLElement;

  function showThinking() {
    stateThink.classList.remove('cb-status-hidden');
    stateTool.classList.add('cb-status-hidden');
  }

  function showTool(icon: string, name: string) {
    stateThink.classList.add('cb-status-hidden');
    stateTool.classList.remove('cb-status-hidden');
    toolIcon.src = icon;
    toolIcon.alt = name;
    toolName.textContent = name + '…';
  }

  async function runScenario(scenario: Scenario) {
    fade(promptEl, () => { promptEl.textContent = scenario.prompt; });
    responseEl.textContent = '';
    showThinking();
    await sleep(400);

    for (const step of scenario.steps) {
      if (step.kind === 'thinking') {
        showThinking();
        fade(responseEl, () => { responseEl.textContent = step.response; });
      } else {
        showTool(step.icon, step.name);
        fade(responseEl, () => { responseEl.textContent = step.response; });
      }
      await sleep(step.duration);
    }

    await sleep(1400);
  }

  function sleep(ms: number) {
    return new Promise(resolve => setTimeout(resolve, ms));
  }

  async function loop() {
    let i = 0;
    while (true) {
      await runScenario(scenarios[i % scenarios.length]);
      i++;
    }
  }

  loop();

  // ─── Scroll-triggered reveals ─────────────────────────
  const revealTargets = document.querySelectorAll('.integrations-strip, .features-header, .feature-card, .step-item, .final-cta-inner');
  revealTargets.forEach(el => el.classList.add('scroll-reveal'));

  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        // Stagger children
        const parent = entry.target.closest('.features-grid, .steps-row');
        if (parent) {
          const siblings = Array.from(parent.querySelectorAll('.scroll-reveal'));
          const idx = siblings.indexOf(entry.target as Element);
          (entry.target as HTMLElement).style.transitionDelay = `${idx * 100}ms`;
        }
        entry.target.classList.add('is-visible');
        observer.unobserve(entry.target);
      }
    });
  }, { threshold: 0.15, rootMargin: '0px 0px -40px 0px' });

  revealTargets.forEach(el => observer.observe(el));
</script>
